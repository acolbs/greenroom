{
  "name": "nba-offseason-gm-simulator",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "homepage": "https://acolbs.github.io/greenroom/",
  "scripts": {
    "sync-headshots": "node ../scripts/sync-headshots.mjs",
    "dev": "vite",
